{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "incremental": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "ES2022",
    "lib": [
      "dom",
      "es2022"
    ],
    "jsx": "react-jsx",
    "plugins": []
  },
  "include": [
    "next-env.d.ts",
    "src/platform/appStateTypes.ts",
    "src/platform/appClient.ts",
    "src/adapters/browserStorage.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
