{
  "name": "kypros-path-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "ci:install": "npm ci",
    "dev": "next dev",
    "build": "next build",
    "build:pages": "node ./scripts/build-pages.mjs",
    "start": "next start",
    "lint:types": "tsc --noEmit",
    "lint:hygiene": "node ./scripts/lint-hygiene.mjs",
    "lint": "npm run lint:types && npm run lint:hygiene",
    "test:build": "tsc -p tsconfig.test.json",
    "test:run": "node --experimental-loader ./tests/support/alias-loader.mjs --test ./.test-dist/tests/adapters ./.test-dist/tests/content ./.test-dist/tests/pages ./.test-dist/tests/platform ./.test-dist/tests/routes",
    "test:e2e:run": "node --experimental-loader ./tests/support/alias-loader.mjs --test ./.test-dist/tests/e2e",
    "test:e2e": "npm run test:build && npm run build && node ./scripts/run-e2e.mjs",
    "test:e2e:pages": "node ./scripts/run-e2e-pages.mjs",
    "test": "npm run test:build && npm run test:run"
  },
  "engines": {
    "node": "20.9.0",
    "npm": "9.2.0"
  },
  "packageManager": "npm@9.2.0",
  "dependencies": {
    "next": "16.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router-dom": "6.30.3"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "puppeteer-core": "24.25.0",
    "typescript": "5.9.3"
  }
}
